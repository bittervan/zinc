{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug zinc-sim rv64ui-p-add",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceRoot}/build/zinc/zinc-simulator/zinc-sim",
            "args": [
                "${input:riscvTest}"
            ],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "externalConsole": false,
        }
    ],
    "inputs": [
        {
            "id": "riscvTest",
            "type": "promptString",
            "description": "RISC-V test ELF path",
            "default": "${workspaceFolder}/build/riscv-tests/isa/rv64ui-p-add"
        }
    ]
}